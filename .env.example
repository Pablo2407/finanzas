# Entorno (development, production, testing)
FLASK_ENV=development

# Flask
SECRET_KEY=tu-clave-secreta-super-segura-aqui-minimo-32-caracteres

# Base de datos
# Para desarrollo: sqlite:///finanzas.db
# Para producción: postgresql://user:password@localhost/finanzas
DATABASE_URL=sqlite:///finanzas.db

# Email (Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-app-password-de-gmail

# Push Notifications (Web Push)
VAPID_PUBLIC_KEY=tu-clave-publica-vapid
VAPID_PRIVATE_KEY=tu-clave-privada-vapid
VAPID_CLAIM_EMAIL=tu-email@gmail.com
